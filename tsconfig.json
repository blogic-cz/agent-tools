{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "#shared": ["./src/shared/index.ts"],
      "#shared/*": ["./src/shared/*"],
      "#config": ["./src/config/index.ts"],
      "#config/*": ["./src/config/*"],
      "#gh/*": ["./src/gh-tool/*"],
      "#k8s/*": ["./src/k8s-tool/*"],
      "#db/*": ["./src/db-tool/*"],
      "#logs/*": ["./src/logs-tool/*"],
      "#az/*": ["./src/az-tool/*"],
      "#guard": ["./src/credential-guard/index.ts"],
      "#session/*": ["./src/session-tool/*"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
